[colors]
background = #222
background-alt = #444
foreground = #dfdfdf
foreground-alt = #555
primary = #ffb52a
secondary = #e60053
blue = #1793d0
alert = #bd2c40
a = #288de0
b = #2795C5
c = #259CAA
d = #259CAA
e = #88BF93
f = #EBE17B
g = #F9C530
h = #F2D356
i = #F3912A
j = #EC5D24
k = #f93b31

[bar/bar1]
monitor = ${env:MONITOR:}
width = 100%
height = 24
;offset-x = 1%
;offset-y = 80%
radius = 0.0
fixed-center = false

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 2
line-color = #f00

border-size = 0
border-color = #00000000

padding-left = 0
padding-right = 2

module-margin-left = 1
module-margin-right = 2

font-0 = fixed:pixelsize=10;1
;font-1 = Unifont:style=Sans-Serif:fontformat=truetype:size=8:antialias=false;0
font-1 = Unifont:style=Sans-Serif
font-2 = Siji:pixelsize=10;1
;font-3 = Font Awesome 5 Free,Font Awesome 5 Free Regular:style=Regular
font-3 = Font Awesome 5 Free,Font Awesome 5 Free Solid:style=Solid
font-4 = Font Awesome 5 Brands,Font Awesome 5 Brands Regular:style=Regular

modules-left = i3
modules-right = filesystem xbacklight pulseaudio memory cpu eth wlan battery0 temperature time-utc date powermenu

tray = right
tray-position = right
tray-padding = 2
tray-transparent = false
tray-background = #0063ff
wm-restack = i3
override-redirect = false

[module/i3]
type = internal/i3
index-sort = true
wrapping-scroll = false

; Available tags:
;   <label-state> (default) - gets replaced with <label-(focused|unfocused|visible|urgent)>
;   <label-mode> (default)
format = <label-state> <label-mode>

; Available tokens:
;   %mode%
; Default: %mode%
label-mode = %mode%
label-mode-padding = 2
label-mode-background = #e60053

; Available tokens:
;   %name%
;   %icon%
;   %index%
;   %output%
; Default: %icon%  %name%
label-focused = %index%
label-focused-foreground = #ffffff
label-focused-background = #3f3f3f
label-focused-underline = #fba922
label-focused-padding = 4

; Available tokens:
;   %name%
;   %icon%
;   %index%
;   %output%
; Default: %icon%  %name%
label-unfocused = %index%
label-unfocused-padding = 4

; Available tokens:
;   %name%
;   %icon%
;   %index%
;   %output%
; Default: %icon%  %name%
label-visible = %index%
label-visible-underline = #555555
label-visible-padding = 4

; Available tokens:
;   %name%
;   %icon%
;   %index%
;   %output%
; Default: %icon%  %name%
label-urgent = %index%
label-urgent-foreground = #000000
label-urgent-background = #bd2c40
label-urgent-padding = 4

; Separator in between workspaces
;label-separator = |
;label-separator-padding = 0
;label-separator-foreground = #ffb52a

[module/filesystem]
type = internal/fs
interval = 25

format-mounted-underline = ${colors.a}

mount-0 = /

;label-mounted = %{F#0a81f5}%mountpoint%%{F-}: %percentage_used%%
label-mounted = %{F#555}ţçá%{F-} %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.foreground-alt}

[module/xbacklight]
type = internal/xbacklight
format-underline = ${colors.b}

enable-scroll = false
;   <label> (default)
;   <ramp>
;   <bar>
format = ţçś <ramp>
format-foreground = ${colors.foreground-alt}

; Available tokens:
;   %percentage% (default)
label = %percentage%%
label-foreground = ${colors.foreground}

; Only applies if <ramp> is used
;ramp-foreground = ${colors.foreground}
;ramp-0 = Ôľä
;ramp-1 = Ôľä
;ramp-2 = Ôľů
;ramp-3 = Ôľć
;ramp-4 = Ôľç
ramp-0 = Ôľü
ramp-1 = Ôľé
ramp-2 = Ôľâ
ramp-3 = Ôľä
ramp-4 = Ôľů
ramp-5 = Ôľć
ramp-6 = Ôľç
ramp-7 = Ôľł
ramp-foreground = ${colors.foreground}
;ramp-0 = ´ćů
;ramp-0-foreground = #666
;ramp-1 = ´ćů
;ramp-1-foreground = #999
;ramp-2 = ´ćů
;ramp-2-foreground = #fff

; Only applies if <bar> is used
bar-width = 10
bar-indicator = |
bar-fill = ÔöÇ
bar-empty = ÔöÇ

[module/pulseaudio]
type = internal/pulseaudio

sink = alsa_output.usb-FiiO_FiiO_USB_DAC-E07K-01.analog-stereo

use-ui-max = false

format-volume-underline = ${colors.c}

interval = 5
; Available tags:
;   <label-volume> (default)
;   <ramp-volume>
;   <bar-volume>
format-volume = <ramp-volume> <label-volume>

; Available tags:
;   <label-muted> (default)
;   <ramp-volume>
;   <bar-volume>
;format-muted = <label-muted>

; Available tokens:
;   %percentage% (default)
;label-volume = %percentage%%

; Available tokens:
;   %percentage% (default)
label-muted = ţłé
label-muted-foreground = #666
label-muted-underline = ${colors.c}

; Only applies if <ramp-volume> is used
ramp-volume-0 = ţłä
ramp-volume-0-foreground = ${colors.foreground-alt}
ramp-volume-1 = ţłâ
ramp-volume-1-foreground = ${colors.foreground-alt}
ramp-volume-2 = ţłâ
ramp-volume-2-foreground = ${colors.foreground-alt}

[module/memory]
type = internal/memory
interval = 2
format-prefix = "ţÇĘ "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = ${colors.d}
label = %percentage_used%%

[module/cpu]
type = internal/cpu
interval = 1
format-prefix = "ţÇŽ "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = ${colors.e}
;label = %percentage%%
label = 
format = <label> <ramp-coreload>

ramp-coreload-spacing = 1
ramp-coreload-0 = Ôľü
ramp-coreload-1 = Ôľé
ramp-coreload-2 = Ôľâ
ramp-coreload-3 = Ôľä
ramp-coreload-4 = Ôľů
ramp-coreload-5 = Ôľć
ramp-coreload-6 = Ôľç
ramp-coreload-7 = Ôľł

[module/eth]
type = internal/network
interface = ens20u1
interval = 3.0

format-connected-underline = ${colors.f}
format-connected-prefix = "ţćť "
format-connected-prefix-foreground = ${colors.foreground-alt}
label-connected = %local_ip%

format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}

[module/battery0]
type = internal/battery
battery = BAT0
adapter = AC
full-at = 99

format-charging = <animation-charging> <label-charging>
format-charging-underline = ${colors.g}

format-discharging = <ramp-capacity> <label-discharging>
format-discharging-underline = ${self.format-charging-underline}

format-full-prefix = "ţł║ "
format-full-prefix-foreground = ${colors.foreground-alt}
format-full-underline = ${self.format-charging-underline}

ramp-capacity-0 = ţłÂ
ramp-capacity-1 = ţłĚ
ramp-capacity-2 = ţłŞ
ramp-capacity-foreground = ${colors.foreground-alt}

animation-charging-0 = ţłÂ
animation-charging-1 = ţłĚ
animation-charging-2 = ţłŞ
animation-charging-foreground = ${colors.foreground-alt}
animation-charging-framerate = 750

[module/wlan]
type = internal/network
interface = wlp59s0
interval = 3.0

format-connected = <ramp-signal> <label-connected>
format-connected-underline = ${colors.h}
label-connected = %essid%

format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}

ramp-signal-0 = ţłś
ramp-signal-1 = ţłÖ
ramp-signal-2 = ţłÜ
ramp-signal-3 = ţłÜ
ramp-signal-4 = ţłÜ
ramp-signal-foreground = ${colors.foreground-alt}

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 60

hwmon-path = /sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input

format = <ramp> <label>
format-underline = ${colors.i}
format-warn = <ramp> <label-warn>
format-warn-underline = ${self.format-underline}

label = %temperature%
label-warn = %temperature%
label-warn-foreground = ${colors.secondary}

ramp-0 = ţâë
ramp-1 = ţâŐ
ramp-2 = ţâő
ramp-foreground = ${colors.foreground-alt}

[module/time-utc]
type = custom/script
exec = TZ=UTC date +"UTC: %m.%d %H:%M" 
format-underline = ${colors.j}
format-prefix = "ţÇľ "
format-prefix-foreground = ${colors.foreground-alt}
interval = 10

[module/date]
type = internal/date
interval = 5

date = " %m.%d"
date-alt = " %m.%d"

time = %H:%M
time-alt = %H:%M:%S

format-prefix = "ţÇľ "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = ${colors.k}

label = Local: %date% %time%

[module/powermenu]
type = custom/menu

format-spacing = 1

;label-open = ţäî
label-open = ţéí
label-open-foreground = ${colors.blue}
label-close = ţüą cancel
label-close-foreground = ${colors.secondary}
label-separator = |
label-separator-foreground = ${colors.foreground-alt}

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = sudo reboot

menu-2-0 = power off
menu-2-0-exec = sudo poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over

[global/wm]
margin-top = 5
margin-bottom = 5

