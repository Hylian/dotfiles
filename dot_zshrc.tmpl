# Setup Zsh Initialization Cache
ZSH_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
[[ -d "$ZSH_CACHE_DIR" ]] || mkdir -p "$ZSH_CACHE_DIR"

# Zsh Completion Caching
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$ZSH_CACHE_DIR/zcompcache"

# Setup Antigen
ANTIGEN_PATH_DEBIAN=/usr/share/zsh-antigen/antigen.zsh
ANTIGEN_PATH_ARCH=/usr/share/zsh/share/antigen.zsh
ANTIGEN_PATH_MAC=/opt/homebrew/share/antigen/antigen.zsh
has_antigen=false

if [[ "$OSTYPE" == "darwin"* && -f "$ANTIGEN_PATH_MAC" ]]; then
  source "$ANTIGEN_PATH_MAC"
  has_antigen=true
elif [[ -f "$ANTIGEN_PATH_ARCH" ]]; then
  source "$ANTIGEN_PATH_ARCH"
  has_antigen=true
elif [[ -f "$ANTIGEN_PATH_DEBIAN" ]]; then
  source "$ANTIGEN_PATH_DEBIAN"
  has_antigen=true
fi

if [[ "$has_antigen" == true ]]; then
  local ANTIGEN_INIT="$HOME/.antigen/init.zsh"
  if [[ ! -f "$ANTIGEN_INIT" || "$HOME/.zshrc" -nt "$ANTIGEN_INIT" ]]; then
    antigen use oh-my-zsh

    antigen bundle direnv
    antigen bundle fd
    antigen bundle pip
    antigen bundle ripgrep
    antigen bundle jeffreytse/zsh-vi-mode
    antigen bundle zsh-users/zsh-autosuggestions
    antigen bundle fzf

    antigen apply
  fi
  source "$ANTIGEN_INIT"
fi

DISABLE_UNTRACKED_FILES_DIRTY="true"
VI_MODE_RESET_PROMPT_ON_MODE_CHANGE=true
VI_MODE_SET_CURSOR=true

if [[ -d "/opt/homebrew/opt/ccache/libexec" ]]; then
  export PATH="/opt/homebrew/opt/ccache/libexec:$PATH"
fi

if [[ -d "$HOME/go/bin" ]]; then
  export PATH="$HOME/go/bin:$PATH"
fi

if [[ -d "$HOME/.fzf/bin" ]]; then
  export PATH="$HOME/.fzf/bin:$PATH"
fi
export PATH="$HOME/.local/bin:$PATH"

export KEYTIMEOUT=5
export WINEARCH=win32
export RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/config"
export BAT_THEME="ansi"

if [[ -f "$HOME/.config/zsh/paths" ]]; then
  source "$HOME/.config/zsh/paths"
fi

if [[ -f "$HOME/.config/zsh/aliases" ]]; then
  source "$HOME/.config/zsh/aliases"
fi

if [[ -f "$HOME/.config/zsh/galiases" ]]; then
  source "$HOME/.config/zsh/galiases"
fi

if [[ -f "$HOME/.config/zsh/gemini" ]]; then
  source "$HOME/.config/zsh/gemini"
fi

# Cached Tool Initializations
if (( $+commands[zellij] )); then
  if [[ ! -f "$ZSH_CACHE_DIR/zellij.zsh" || "$commands[zellij]" -nt "$ZSH_CACHE_DIR/zellij.zsh" ]]; then
    zellij setup --generate-auto-start zsh >! "$ZSH_CACHE_DIR/zellij.zsh" 2>/dev/null
    zcompile "$ZSH_CACHE_DIR/zellij.zsh" 2>/dev/null
  fi
  source "$ZSH_CACHE_DIR/zellij.zsh"
fi

if (( $+commands[zoxide] )); then
  if [[ ! -f "$ZSH_CACHE_DIR/zoxide.zsh" || "$commands[zoxide]" -nt "$ZSH_CACHE_DIR/zoxide.zsh" ]]; then
    zoxide init zsh --cmd j >! "$ZSH_CACHE_DIR/zoxide.zsh" 2>/dev/null
    zcompile "$ZSH_CACHE_DIR/zoxide.zsh" 2>/dev/null
  fi
  source "$ZSH_CACHE_DIR/zoxide.zsh"
fi

if (( $+commands[starship] )); then
  if [[ ! -f "$ZSH_CACHE_DIR/starship.zsh" || "$commands[starship]" -nt "$ZSH_CACHE_DIR/starship.zsh" ]]; then
    starship init zsh >! "$ZSH_CACHE_DIR/starship.zsh" 2>/dev/null
    zcompile "$ZSH_CACHE_DIR/starship.zsh" 2>/dev/null
  fi
  source "$ZSH_CACHE_DIR/starship.zsh"
fi

# Zsh Hooks
function refresh {
  if [ -n "$TMUX" ] && [ -n "$SSH_TTY" ] && [ -z "$WAYLAND_DISPLAY" ]; then
    export $(tmux show-env WAYLAND_DISPLAY 2> /dev/null)
  elif [ -n "$ZELLIJ" ] && [ -f /tmp/wayland_display ]; then
    export WAYLAND_DISPLAY=$(< /tmp/wayland_display)
  fi
}

function preexec {
  refresh
}

zellij_tab_name_update() {
    local current_dir=$PWD
    if [[ $current_dir == $HOME ]]; then
        current_dir="~"
    else
        current_dir=${current_dir##*/}
    fi
    ( command zellij action rename-tab "$current_dir" >/dev/null 2>&1 & )
}

zellij_status_update() {
    ( command zellij pipe "zjstatus::rerun::command_git_branch" >/dev/null 2>&1 & )
}

if [[ -n $ZELLIJ ]]; then
    chpwd_functions+=(zellij_tab_name_update zellij_status_update)
fi

# FZF
if (( $+commands[fdfind] )); then
  export FD_COMMAND="fdfind"
else
  export FD_COMMAND="fd"
fi
export FZF_ALT_C_OPTS="--preview 'tree -L 1 -C {}'"
export FZF_ALT_C_COMMAND="$FD_COMMAND -t d -t l -d 3"
export FZF_CTRL_R_OPTS="
  --with-nth 2..
  --bind 'ctrl-t:track+clear-query'
  --bind 'ctrl-y:execute-silent(echo -n {2..} | wl-copy)+abort'"
{{ if ne .theme "dark" -}}
export FZF_DEFAULT_OPTS='--color=bg+:#f3f5d9,fg:#5c6a72,fg+:#5c6a72,border:#8da101,spinner:#f85552,hl:#f85552,header:#dfa000,info:#35a77c,pointer:#f85552,marker:#f85552,prompt:#fffbef,hl+:#fa8987'
{{- else -}}
{{- end }}

if (( $+commands[fzf] )); then
  if [[ ! -f "$ZSH_CACHE_DIR/fzf.zsh" || "$commands[fzf]" -nt "$ZSH_CACHE_DIR/fzf.zsh" ]]; then
    fzf --zsh >! "$ZSH_CACHE_DIR/fzf.zsh" 2>/dev/null
    zcompile "$ZSH_CACHE_DIR/fzf.zsh" 2>/dev/null
  fi
  zvm_after_init_commands+=("source '$ZSH_CACHE_DIR/fzf.zsh'")
fi

# Widgets
if [[ -f "$HOME/.config/zsh/widgets" ]]; then
  source "$HOME/.config/zsh/widgets"
fi

# Lazy NVM Sourcing
if [[ -d "$HOME/.nvm" ]]; then
  export NVM_DIR="$HOME/.nvm"
  lazy_load_nvm() {
    unset -f nvm node npm npx yarn pnpm 2>/dev/null
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
  }
  for cmd in nvm node npm npx yarn pnpm; do
    eval "$cmd() { lazy_load_nvm; $cmd \"\$@\"; }"
  done
fi
