[global]
monitor = 1
follow = none
width = 200
offset = 8x10
separator_color = frame
separator_height = 0
font = Atkinson Hyperlegible 12
mouse_left_click = close_current
mouse_middle_click = do_action, close_current
mouse_right_click = close_all
max_icon_size = 10
format = "<b> %s</b>\n  %b"
vertical_alignment = top
alignment = right

corner_radius = 0
frame_width = 1
frame_color = "#FFD36Bc0"
background = "#18848Ee0"
foreground = "#FC8D95e0"

[urgency_low]
timeout = 1

[urgency_normal]
timeout = 2

[urgency_critical]
timeout = 10
