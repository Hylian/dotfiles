{
  "height": 24,
  "spacing": 4,
  "output": ["Dell Inc. Dell S2417DG YNY1D89709RU"],
  "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
  "modules-center": [],
  "modules-right": ["pulseaudio", "backlight", "network", "disk", "memory", "cpu", "temperature", "battery", "clock", "tray"],

  "sway/workspaces": {
    "all-outputs": true,
    "persistent_workspaces": {
      "1": [],
      "6": [],
    }
  },

  "sway/window": {
    "all-outputs": true
  },

  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },

  "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "´őĺ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
  },

  "tray": {
      // "icon-size": 21,
      "spacing": 10
  },

  "clock": {
      "timezone": "America/New_York",
      "format": "{:%a %b %d ´ü│  %I:%M %p} ´ÇŚ",
  },

  "battery": {
      "bat": "BAT0",
      "adapter": "AC",
      "states": {
        "warning": 30,
        "critical": 15
      },
      "full-at": 99,
      "format": "{capacity}% {time} {icon} ",
