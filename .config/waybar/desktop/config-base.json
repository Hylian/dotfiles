{
  "height": 24,
  "spacing": 4,
  "output": ["DP-2"],
  "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
  "modules-center": [],
  "modules-right": ["custom/wl-gammarelay-temperature", "wireplumber", "disk", "cpu", "memory", "temperature", "clock", "tray"],

  "sway/workspaces": {
    "all-outputs": true,
    "persistent_workspaces": {
      "1": [],
      "6": []
    }
  },

  "sway/window": {
    "all-outputs": true
  },

  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },

  "sway/scratchpad": {
    "format": "{icon} {count}",
    "show-empty": false,
    "format-icons": ["", "´őĺ"],
    "tooltip": true,
    "tooltip-format": "{app}: {title}"
  },

  "tray": {
    "spacing": 10
  },

  "clock": {
    "timezone": "America/New_York",
    "format": "{:%a %b %d ´ü│  %I:%M %p} ´ÇŚ"
  },

  "battery": {
    "bat": "BAT0",
    "adapter": "AC",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "full-at": 99,
    "format": "{capacity}% {time}{icon}",
    "format-time": "{H}h{M}m ",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
    "format-charging": "{capacity}% ´çŽ "
  },

  "disk": {
    "format": "{percentage_used}% [{used}] ´éá",
    "interval": 30,
    "path": "/"
  },

  "cpu": {
    "format": "{usage:2}% [{min_frequency:.2f}GHz {avg_frequency:.2f}GHz {max_frequency:.2f}GHz] ´őŤ",
    "interval": 1,
    "tooltip": false
  },

  "memory": {
    "format": "{}% [{used:.2f}GiB] ´âë"
  },

  "temperature": {
    "thermal-zone": 9,
    "critical-threshold": 80,
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["´őë"]
  },

  "network": {
    "format-wifi": "{signalStrength}% ´çź",
    "format-ethernet": "´Ť┐",
    "tooltip-format": "{ifname} via {gwaddr} ´Ť┐",
    "format-linked": "{ifname} (No IP) ´Ť┐",
    "format-disconnected": "Disconnected ÔÜá",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },

  "wireplumber": {
    "format": "{node_name} {volume}% ´Çž",
    "format-muted": "´ÇŽ",
    "format-icons": ["´ÇŽ", "´Çž", "´ÇĘ"]
  },

  "pulseaudio": {
    "scroll-step": 1,
    "format": "{desc:.10} {volume}% {icon} {format_source}",
    "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
    "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
    "format-muted": "´ÇŽ {format_source}",
    "format-source": "{volume}% ´ä░",
    "format-source-muted": "´ä▒",
    "format-icons": {
      "headphone": "´Çą",
      "hands-free": "´ľÉ",
      "headset": "´ľÉ",
      "phone": "´éĽ",
      "portable": "´éĽ",
      "car": "´ć╣",
      "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
    },
    "on-click": "pavucontrol"
  },

  "wireplumber": {
    "format": "{node_name} {volume}% {icon}",
    "format-muted": "´ÇŽ",
    "on-click": "pavucontrol",
    "format-icons": ["´ÇŽ", "´Çž", "´ÇĘ"]
  },

  "backlight": {
    "device": "intel_backlight",
    "format": "{percent}% {icon}",
    "format-icons": ["´ćů", "´äĹ"]
  },

  "custom/wl-gammarelay-temperature": {
    "format": "{} ´ćć",
    "exec": "wl-gammarelay --subscribe Temperature",
    "on-scroll-up": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n +100",
    "on-scroll-down": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n -100"
  }
}
