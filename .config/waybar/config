{
  "height": 30,
  "spacing": 4,
  "output": ["DP-1"],
  "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad", "sway/window", "custom/media"],
  "modules-center": [],
  "modules-right": ["wireplumber", "network", "cpu", "memory", "temperature", "clock", "tray"],

  "sway/workspaces": {
    "all-outputs": true
  },

  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },

  "sway/window": {
    "all-outputs": true,
    "icon": true
  },

  "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "´őĺ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
  },

  "tray": {
      // "icon-size": 21,
      "spacing": 10
  },

  "clock": {
      "timezone": "America/New_York",
      //"tooltip-format": "<span font='Atkinson Monolegible 16'><big>{:%Y %B}</big>\n<tt>{calendar}</tt></span>",
      "format": "{:%a %b %d ´ü│  %I:%M %p} ´ÇŚ",

      "calendar-weeks-pos": "right",
      "today-format": "<span color='#ff6699'><b><u>{}</u></b></span>",
      "format-calendar": "<span color='#ecc6d9'><b>{}</b></span>",
      "format-calendar-weeks": "",
      "format-calendar-weekdays": "<span color='#ffcc66'><b>{}</b></span>",
      "on-scroll": {
        "calendar": 0
      }
  },

  "cpu": {
      "format": "{usage:2}% {min_frequency:.2f} GHz / {avg_frequency:.2f} GHz / {max_frequency:.2f} GHz ´őŤ",
      "interval": 1,
      "tooltip": false
  },

  "memory": {
      "format": "{}% ´âë"
  },

  "temperature": {
      "thermal-zone": 0,
      "hwmon-path": "/sys/devices/pci0000:00/0000:00:18.3/hwmon/hwmon4/temp3_input",
      "critical-threshold": 80,
      // "format-critical": "{temperatureC}┬░C {icon}",
      "format": "{temperatureC}┬░C {icon}",
      "format-icons": ["´Łź", "´őë", "´Łę"]
  },

  "network": {
      // "interface": "wlp2*", // (Optional) To force the use of this interface
      "format-wifi": "{essid} ({signalStrength}%) ´çź",
      "format-ethernet": "{ipaddr}/{cidr} ´×ľ",
      "tooltip-format": "{ifname} via {gwaddr} ´×ľ",
      "format-linked": "{ifname} (No IP) ´×ľ",
      "format-disconnected": "Disconnected ÔÜá",
      "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },

  "wireplumber": {
    "format": "{node_name} {volume}% ´Çž",
    "format-muted": "´ÇŽ",
    "format-icons": ["´ÇŽ", "´Çž", "´ÇĘ"]
  },

  "pulseaudio": {
      // "scroll-step": 1, // %, can be a float
      "format": "{volume}% {icon} {format_source}",
      "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
      "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
      "format-muted": "´Üę {format_source}",
      "format-source": "{volume}% ´ä░",
      "format-source-muted": "´ä▒",
      "format-icons": {
          "headphone": "´Çą",
          "hands-free": "´ľÉ",
          "headset": "´ľÉ",
          "phone": "´éĽ",
          "portable": "´éĽ",
          "car": "´ć╣",
          "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
      },
      "on-click": "pavucontrol"
  },

  "custom/media": {
      "format": "{icon} {}",
      "return-type": "json",
      "max-length": 40,
      "format-icons": {
          "spotify": "´ć╝",
          "default": "­čÄť"
