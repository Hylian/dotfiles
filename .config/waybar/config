{
  "height": 30,
  "spacing": 4,
  "output": ["DP-1"],
  "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad", "sway/window", "custom/media"],
  "modules-center": [],
  "modules-right": ["wireplumber", "network", "disk", "cpu", "memory", "temperature", "clock", "tray"],

  "sway/workspaces": {
    "all-outputs": true,
    "persistent_workspaces": {
      "1": [],
      "6": []
    }
  },

  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },

  "sway/window": {
    "all-outputs": true,
    "icon": true
  },

  "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", ""],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
  },

  "tray": {
      // "icon-size": 21,
      "spacing": 10
  },

  "disk": {
      "format": "{percentage_used}% [{used}] ",
      "interval": 30,
      "path": "/",
  },

  "clock": {
      "timezone": "America/New_York",
      //"tooltip-format": "<span font='Atkinson Monolegible 16'><big>{:%Y %B}</big>\n<tt>{calendar}</tt></span>",
      "format": "{:%a %b %d   %I:%M %p} ",

      "calendar-weeks-pos": "right",
      "today-format": "<span color='#ff6699'><b><u>{}</u></b></span>",
      "format-calendar": "<span color='#ecc6d9'><b>{}</b></span>",
      "format-calendar-weeks": "",
      "format-calendar-weekdays": "<span color='#ffcc66'><b>{}</b></span>",
      "on-scroll": {
        "calendar": 0
      }
  },

  "cpu": {
      "format": "Min[{min_frequency:.2f}GHz] Avg[{avg_frequency:.2f}GHz] Max[{max_frequency:.2f}GHz] {usage:2}% ",
      "interval": 1,
      "tooltip": false
  },

  "memory": {
      "format": "{}% [{used:.2f}GiB] "
  },

  "temperature": {
      "thermal-zone": 0,
      "hwmon-path": "/sys/devices/pci0000:00/0000:00:18.3/hwmon/hwmon4/temp3_input",
      "critical-threshold": 80,
      // "format-critical": "{temperatureC}°C {icon}",
      "format": "{temperatureC}°C {icon}",
      "format-icons": ["", "", ""]
  },

  "network": {
      // "interface": "wlp2*", // (Optional) To force the use of this interface
      "format-wifi": "{essid} ({signalStrength}%) ",
      "format-ethernet": "{ipaddr}/{cidr} ",
      "tooltip-format": "{ifname} via {gwaddr} ",
      "format-linked": "{ifname} (No IP) ",
      "format-disconnected": "Disconnected ⚠",
      "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },

  "wireplumber": {
    "format": "{node_name} {volume}% ",
    "format-muted": "",
    "format-icons": ["", "", ""]
  },

  "pulseaudio": {
      // "scroll-step": 1, // %, can be a float
      "format": "{volume}% {icon} {format_source}",
      "format-bluetooth": "{volume}% {icon} {format_source}",
      "format-bluetooth-muted": " {icon} {format_source}",
      "format-muted": " {format_source}",
      "format-source": "{volume}% ",
      "format-source-muted": "",
      "format-icons": {
          "headphone": "",
          "hands-free": "",
          "headset": "",
          "phone": "",
          "portable": "",
          "car": "",
          "default": ["", "", ""]
      },
      "on-click": "pavucontrol"
  },

  "custom/media": {
      "format": "{icon} {}",
      "return-type": "json",
      "max-length": 40,
      "format-icons": {
          "spotify": "",
          "default": "🎜"
      },
      "escape": true,
      "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
      // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
  }
}
