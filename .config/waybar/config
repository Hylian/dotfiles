{
  "height": 24,
  "spacing": 4,
  "output": ["eDP-1"],
  "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
  "modules-center": [],
  "modules-right": ["pulseaudio", "backlight", "network", "disk", "memory", "cpu", "temperature", "battery", "clock", "tray"],

  "sway/workspaces": {
    "all-outputs": true,
    "persistent_workspaces": {
      "1": [],
    }
  },

  "sway/window": {
    "all-outputs": true
  },

  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },

  "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "п‹’"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
  },

  "tray": {
      // "icon-size": 21,
      "spacing": 10
  },

  "clock": {
      "timezone": "America/New_York",
      "format": "{:%a %b %d пЃі  %I:%M %p} пЂ—",
  },

  "battery": {
      "bat": "BAT0",
      "adapter": "AC",
      "states": {
        "warning": 30,
        "critical": 15
      },
      "full-at": 99,
      "format": "{capacity}% {time} {icon} ",
      "format-time": "{H}h{M}m",
      "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],
      "format-charging": "{capacity}% п‡¦ "
  },

  "disk": {
      "format": "{percentage_used}% [{used}] п‚ ",
      "interval": 30,
      "path": "/",
  },

  "cpu": {
      "format": "Min[{min_frequency:.2f}GHz] Avg[{avg_frequency:.2f}GHz] Max[{max_frequency:.2f}GHz] {usage:2}% п‹›",
      "interval": 1,
      "tooltip": false
  },

  "memory": {
      "format": "{}% [{used:.2f}GiB] пѓ‰"
  },

  "temperature": {
      "thermal-zone": 9,
      "critical-threshold": 80,
      // "format-critical": "{temperatureC}В°C {icon}",
      "format": "{temperatureC}В°C {icon}",
      "format-icons": ["п‹‰"]
  },

  "network": {
      // "interface": "wlp2*", // (Optional) To force the use of this interface
      "format-wifi": "{essid} ({signalStrength}%) п‡«",
      "format-ethernet": "{ipaddr}/{cidr} п›ї",
      "tooltip-format": "{ifname} via {gwaddr} п›ї",
      "format-linked": "{ifname} (No IP) п›ї",
      "format-disconnected": "Disconnected вљ ",
      "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },

  "wireplumber": {
    "format": "{node_name} {volume}% пЂ§",
    "format-muted": "пЂ¦",
    "format-icons": ["пЂ¦", "пЂ§", "пЂЁ"]
  },

  "pulseaudio": {
      // "scroll-step": 1, // %, can be a float
      "format": "{volume}% {icon} {format_source}",
      "format-bluetooth": "{volume}% {icon}пЉ” {format_source}",
      "format-bluetooth-muted": "пљ© {icon}пЉ” {format_source}",
      "format-muted": "пЂ¦ {format_source}",
      "format-source": "{volume}% п„°",
      "format-source-muted": "п„±",
      "format-icons": {
          "headphone": "пЂҐ",
          "hands-free": "п–ђ",
          "headset": "п–ђ",
          "phone": "п‚•",
          "portable": "п‚•",
          "car": "п†№",
          "default": ["пЂ¦", "пЂ§", "пЂЁ"]
      },
      "on-click": "pavucontrol"
  },

  "backlight": {
    "device": "intel_backlight",
    "format": "{percent}% {icon}",
    "format-icons": ["п†…", "п„‘"]
  },

  "custom/media": {
      "format": "{icon} {}",
      "return-type": "json",
      "max-length": 40,
      "format-icons": {
          "spotify": "п†ј",
          "default": "рџЋњ"
      },
      "escape": true,
      "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
      // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
  },

  "custom/wl-gammarelay-temperature": {
    "format": "{} п††",
    "exec": "wl-gammarelay --subscribe Temperature",
    "on-scroll-up": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n +100",
    "on-scroll-down": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n -100"
  }
}
