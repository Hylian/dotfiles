{
    "workbench.colorTheme": "One Dark Pro Darker",
    "vscode-neovim.neovimExecutablePaths.linux": "/usr/bin/nvim",
    "vscode-neovim.neovimInitVimPaths.linux": "~/.config/nvim/init.vim",
    "editor.fontFamily": "'Atkinson Monolegible', 'Droid Sans Mono', 'UbuntuMono Nerd Font', 'monospace', monospace",
    "editor.codeLensFontFamily": "'Atkinson Hyperlegible'",
    "terminal.external.linuxExec": "kitty",
    "security.workspace.trust.untrustedFiles": "open",
    "cmake.configureOnOpen": false,
    "cmake.configureOnEdit": false,
    "terminal.integrated.fontFamily": "'Atkinson Monolegible'",
    "update.mode": "none",
    "telemetry.telemetryLevel": "off",
    "extensions.experimental.affinity": {
      "asvetliakov.vscode-neovim": 1
    },
    "git.detectSubmodulesLimit": 100,
    "C_Cpp.intelliSenseEngine": "disabled",
    "zenMode.hideTabs": false,
    "editor.tabSize": 2,
    "editor.minimap.showSlider": "always",
    "editor.minimap.size": "fill",
    "docsView.documentationView.updateMode": "sticky",
    "editor.hover.delay": 100,
    "terminal.integrated.gpuAcceleration": "on",
    "workbench.startupEditor": "none",
    "window.zoomLevel": 1,
    "vscode_custom_css.imports": ["file:///home/shined/scripts/code-custom.css"]
}
