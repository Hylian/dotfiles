                command_git_branch_command    "sh -c 'b=$(git branch --show-current 2>/dev/null || git rev-parse --short HEAD 2>/dev/null); [ -n \"$b\" ] && { [ -n \"$(git status --porcelain=v1 -uno --ignore-submodules=dirty 2>/dev/null)\" ] && echo \"$b ā—¸\" || echo \"$b\"; }'"
