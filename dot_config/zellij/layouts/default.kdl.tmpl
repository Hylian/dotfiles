                mode_locked        "#[fg=#E67E80]ī‚¶#[bg=#E67E80,fg=#374145] LOCKED #[fg=#E67E80,bg=#272E33]ī‚°"
                mode_resize        "#[fg=#A7C080]ī‚¶#[bg=#A7C080,fg=#374145] RESIZE #[fg=#A7C080,bg=#272E33]ī‚°"
                mode_pane          "#[fg=#A7C080]ī‚¶#[bg=#A7C080,fg=#374145]  PANE  #[fg=#A7C080,bg=#272E33]ī‚°"
                mode_tab           "#[fg=#A7C080]ī‚¶#[bg=#A7C080,fg=#374145]  TAB   #[fg=#A7C080,bg=#272E33]ī‚°"
                mode_scroll        "#[fg=#A7C080]ī‚¶#[bg=#A7C080,fg=#374145] SCROLL #[fg=#A7C080,bg=#272E33]ī‚°"
                mode_enter_search  "#[fg=#A7C080]ī‚¶#[bg=#A7C080,fg=#374145] SEARCH #[fg=#A7C080,bg=#272E33]ī‚°"
                mode_search        "#[fg=#A7C080]ī‚¶#[bg=#A7C080,fg=#374145] SEARCH #[fg=#A7C080,bg=#272E33]ī‚°"
                mode_rename_tab    "#[fg=#A7C080]ī‚¶#[bg=#A7C080,fg=#374145] RENAME #[fg=#A7C080,bg=#272E33]ī‚°"
                mode_rename_pane   "#[fg=#A7C080]ī‚¶#[bg=#A7C080,fg=#374145] RENAME #[fg=#A7C080,bg=#272E33]ī‚°"
                mode_session       "#[fg=#A7C080]ī‚¶#[bg=#A7C080,fg=#374145] SESSN  #[fg=#A7C080,bg=#272E33]ī‚°"
                mode_move          "#[fg=#A7C080]ī‚¶#[bg=#A7C080,fg=#374145] MOVE   #[fg=#A7C080,bg=#272E33]ī‚°"
                mode_prompt        "#[fg=#A7C080]ī‚¶#[bg=#A7C080,fg=#374145] PROMPT #[fg=#A7C080,bg=#272E33]ī‚°"

