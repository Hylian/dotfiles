                mode_session       "#[fg=#8DA101]ī‚¶#[bg=#8DA101,fg=#F2EFDF] SESSN  #[fg=#8DA101,bg=#FFFBEF]ī‚°"
                mode_move          "#[fg=#8DA101]ī‚¶#[bg=#8DA101,fg=#F2EFDF] MOVE   #[fg=#8DA101,bg=#FFFBEF]ī‚°"
                mode_prompt        "#[fg=#8DA101]ī‚¶#[bg=#8DA101,fg=#F2EFDF] PROMPT #[fg=#8DA101,bg=#FFFBEF]ī‚°"

                tab_normal   "#[fg=#F8F5E4,bg=#FFFBEF]ī‚²#[bg=#F8F5E4,fg=#BEC5B2] {name} #[fg=#F8F5E4,bg=#FFFBEF]ī‚°#[fg=#F8F5E4,bg=#FFFBEF] "
