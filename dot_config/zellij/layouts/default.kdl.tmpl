                mode_tab           "#[fg=#8DA101]ī‚¶#[bg=#8DA101,fg=#F2EFDF]  TAB   #[fg=#8DA101,bg=#FFFBEF]ī‚°"
                mode_scroll        "#[fg=#8DA101]ī‚¶#[bg=#8DA101,fg=#F2EFDF] SCROLL #[fg=#8DA101,bg=#FFFBEF]ī‚°"
                mode_enter_search  "#[fg=#8DA101]ī‚¶#[bg=#8DA101,fg=#F2EFDF] SEARCH #[fg=#8DA101,bg=#FFFBEF]ī‚°"
                mode_search        "#[fg=#8DA101]ī‚¶#[bg=#8DA101,fg=#F2EFDF] SEARCH #[fg=#8DA101,bg=#FFFBEF]ī‚°"
