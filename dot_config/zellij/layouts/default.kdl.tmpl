                command_git_branch_format     "#[fg=#DF69BA,bg=#272E33]ī‚²#[bg=#DF69BA,fg=#374145] ī‚  {stdout} #[fg=#7FBBB3,bg=#DF69BA]ī‚²"
                command_git_branch_rendermode "static"
